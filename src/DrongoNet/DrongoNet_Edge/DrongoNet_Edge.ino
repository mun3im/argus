// =========================================================
// FLASH MEMORY BREAKDOWN
// =========================================================
void printFlashMemory() {
  Serial.println(F("\n╔══════════════════════════════════════════╗"));
  Serial.println(F("║        FLASH MEMORY BREAKDOWN            ║"));
  Serial.println(F("╚══════════════════════════════════════════╝"));

  mbed::FlashIAP flash;
  if (flash.init() == 0) {
    uint32_t flash_start = flash.get_flash_start();
    uint32_t flash_size  = flash.get_flash_size();
    // Do NOT call flash.deinit() — on STM32H7, HAL_DeInit() resets the flash
    // peripheral clock, stalling CPU instruction fetch → HardFault crash.

    uint32_t app_end          = FLASHIAP_APP_ROM_END_ADDR;
    uint32_t app_size         = app_end - flash_start;
    uint32_t remaining_after  = (flash_start + flash_size) - app_end;
    uint32_t model_size       = drongonet_edge_len;
    uint32_t remaining_before = remaining_after + model_size;

    Serial.print(F("  Total Flash Size            : "));
    Serial.print(flash_size);
    Serial.print(F(" B  = "));
    Serial.print(flash_size / 1024.0f / 1024.0f, 2);
    Serial.println(F(" MB"));

    Serial.print(F("  Flash Start Address         : 0x"));
    Serial.println(flash_start, HEX);

    Serial.print(F("  Application End Address     : 0x"));
    Serial.println(app_end, HEX);

    Serial.print(F("  Application Size (with model): "));
    Serial.print(app_size);
    Serial.print(F(" B  = "));
    Serial.print(app_size / 1024.0f, 2);
    Serial.println(F(" KB"));

    Serial.print(F("  Model Size in Flash         : "));
    Serial.print(model_size);
    Serial.print(F(" B  = "));
    Serial.print(model_size / 1024.0f, 2);
    Serial.println(F(" KB  (DrongoNet-edge)"));

    Serial.println(F("  ──────────────────────────────────────────"));
    Serial.print(F("  Remaining Flash BEFORE model loaded : "));
    Serial.print(remaining_before);
    Serial.print(F(" B  = "));
    Serial.print(remaining_before / 1024.0f, 2);
    Serial.println(F(" KB"));

    Serial.print(F("  Remaining Flash AFTER model loaded  : "));
    Serial.print(remaining_after);
    Serial.print(F(" B  = "));
    Serial.print(remaining_after / 1024.0f, 2);
    Serial.println(F(" KB"));
  } else {
    Serial.println(F("  [ERR] Failed to initialize FlashIAP."));
  }
}

