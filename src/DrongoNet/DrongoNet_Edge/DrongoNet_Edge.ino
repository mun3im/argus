// DWT Cycle Counter — µs-accurate timing
// At 480 MHz: 1 cycle ≈ 2.083 ns → divide by 480 for µs.
// =========================================================
#define DWT_ENABLE()  do { CoreDebug->DEMCR |= CoreDebug_DEMCR_TRCENA_Msk; \
                           DWT->CYCCNT = 0; DWT->CTRL |= DWT_CTRL_CYCCNTENA_Msk; } while(0)
#define DWT_RESET()   do { DWT->CYCCNT = 0; } while(0)
#define DWT_CYCLES()  (DWT->CYCCNT)
#define DWT_US(cyc)   ((float)(cyc) / 480.0f)

// =========================================================
// CMSIS-DSP FFT instance + working buffers
// ── DTCM placement ───────────────────────────────────────
// These arrays form the FFT working set (~10 KB total).
// Placing them in DTCM (0x20000000, 128 KB, zero-wait)
// eliminates AXI SRAM cache-miss stalls in arm_rfft_fast_f32.
//
// IMPORTANT: Standard DMA cannot access DTCM on STM32H7.
// captureAudio() uses CPU-polled analogRead() — safe here.
// =========================================================
static arm_rfft_fast_instance_f32 fftInstance; // ~76 B state struct

__attribute__((section(".dtcmram")))
static float hannWindow[MEL_N_FFT];        // 1024 floats = 4 KB → DTCM

__attribute__((section(".dtcmram")))
static float fftBuf[MEL_N_FFT];           // 1024 floats = 4 KB → DTCM (in/out)

__attribute__((section(".dtcmram")))
static float powerSpectrum[MEL_N_FFT_BINS]; // 513 floats = 2 KB → DTCM

