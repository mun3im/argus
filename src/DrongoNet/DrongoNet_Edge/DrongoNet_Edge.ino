  Serial.println(F("  [HEAP  — dynamic Mbed allocations]"));
  Serial.print(F("    current live bytes        : "));
  Serial.print(heap.current_size);
  Serial.println(F(" B"));
  Serial.print(F("    peak (max ever)           : "));
  Serial.print(heap.max_size / 1024.0f, 2);
  Serial.println(F(" KB"));
  Serial.print(F("    alloc failures            : "));
  Serial.println(heap.alloc_fail_cnt);

  Serial.println(F("  [STACK — Mbed OS HWM per thread]"));
  int cnt = osThreadGetCount();
  if (cnt > 0 && cnt <= 32) {
    mbed_stats_stack_t *stk =
        (mbed_stats_stack_t *)malloc(cnt * sizeof(mbed_stats_stack_t));
    if (stk) {
      int got = mbed_stats_stack_get_each(stk, cnt);
      for (int i = 0; i < got; i++) {
        uint32_t used = stk[i].max_size;
        uint32_t res  = stk[i].reserved_size;
        Serial.print(F("    Thread 0x"));
        Serial.print(stk[i].thread_id, HEX);
        Serial.print(F("  HWM="));
        Serial.print(used);
        Serial.print(F("B / res="));
        Serial.print(res);
        Serial.print(F("B  free="));
        Serial.println((res > used) ? (res - used) : 0);
      }
      free(stk);
    }
  }

  // ── Transient RAM summary ────────────────────────────────
  uint32_t stack_free = 0;
  int cnt2 = osThreadGetCount();
  if (cnt2 > 0 && cnt2 <= 32) {
    mbed_stats_stack_t *stk =
        (mbed_stats_stack_t *)malloc(cnt2 * sizeof(mbed_stats_stack_t));
    if (stk) {
      int got      = mbed_stats_stack_get_each(stk, cnt2);
      uint32_t max_res = 0;
      for (int i = 0; i < got; i++) {
        if (stk[i].reserved_size > max_res) {
          max_res    = stk[i].reserved_size;
          stack_free = (stk[i].reserved_size > stk[i].max_size)
                         ? (stk[i].reserved_size - stk[i].max_size) : 0;
        }
      }
      free(stk);
    }
  }

  uint32_t heap_free   = (heap.reserved_size > heap.current_size)
                           ? (heap.reserved_size - heap.current_size) : 0;
  uint32_t arena_used  = (uint32_t)interpreter->arena_used_bytes();
  uint32_t arena_slack = (uint32_t)kTensorArenaSize - arena_used;
  uint32_t internal_free = stack_free + heap_free;

  Serial.println(F("  [TRANSIENT RAM SUMMARY]"));
  Serial.print(F("    Remaining Main Stack Space (Internal) : "));
  Serial.print(stack_free);
  Serial.println(F(" B"));
  Serial.print(F("    Remaining Mbed Heap Space  (Internal) : "));
  Serial.print(heap_free);
  Serial.println(F(" B"));
  Serial.print(F("    Unused Tensor Arena Slack  (External) : "));
  Serial.print(arena_slack);
  Serial.println(F(" B"));
  Serial.println(F("    ──────────────────────────────────────────"));
  Serial.print(F("    Total Free Internal Transient RAM (SRAM)  : "));
  Serial.print(internal_free);
  Serial.print(F(" B  = "));
  Serial.print(internal_free / 1024.0f, 2);
  Serial.println(F(" KB"));
  Serial.print(F("    Total Free External Transient RAM (SDRAM) : "));
  Serial.print(arena_slack);
  Serial.print(F(" B  = "));
  Serial.print(arena_slack / 1024.0f, 2);
  Serial.println(F(" KB"));
}

void printStageDelta(const char *label, const StageRAM &before,
                     const StageRAM &after) {
  Serial.print(F("  Stage ["));
  Serial.print(label);
  Serial.print(F("]  stack HWM delta = +"));
  int32_t ds = (int32_t)after.stack_hwm - (int32_t)before.stack_hwm;
  int32_t dh = (int32_t)after.heap_peak - (int32_t)before.heap_peak;
  Serial.print(ds >= 0 ? ds : 0);
  Serial.print(F(" B   heap peak delta = +"));
  Serial.println(dh >= 0 ? dh : 0);
}

// =========================================================
// fast_log10f — IEEE-754 exponent trick (~10 cycles vs ~150)
// =========================================================
// Extracts the binary exponent from the float bit pattern.
// Total error < 0.5 dB — negligible after min-max normalisation.
static inline float fast_log10f(float x) {
  if (x <= 0.0f) return -100.0f;
  uint32_t bits;
  memcpy(&bits, &x, sizeof(bits));
  int   exp  = (int)((bits >> 23) & 0xFF) - 127;
  float mant = (float)(bits & 0x7FFFFF) * (1.0f / (float)0x800000);
  return (exp + mant) * 0.30103f; // log10 = log2 × log10(2)
}

// =========================================================
// CMSIS-DSP FFT + Hann Window + Filterbank Initialisation
// =========================================================
// Call once from setup(). Computes the 1024-point Hann window,
// initialises the CMSIS Real-FFT instance, and pre-bakes the
// flat triangular filterbank weight table.
//
// Why arm_rfft_fast_f32?
//   • Real FFT exploits conjugate symmetry → ~2× faster than
//     the equivalent complex FFT for the same N.
//   • CMSIS assembly is hand-optimised for Cortex-M7 FPU/SIMD.
void initMelFFT() {
  // ── Hann window ────────────────────────────────────────────
  for (int i = 0; i < MEL_N_FFT; i++) {
    hannWindow[i] = 0.5f * (1.0f - cosf(2.0f * (float)M_PI * i / (float)MEL_N_FFT));
  }

  // ── CMSIS Real-FFT instance ─────────────────────────────────
  arm_rfft_fast_init_f32(&fftInstance, MEL_N_FFT);

  // ── Pre-bake flat filterbank weight table ───────────────────
  // For each mel filter m, the triangular weight at FFT bin k:
  //   rising  (startBin ≤ k < peakBin):  w = (k - start) / (peak - start)
  //   falling (peakBin  ≤ k < endBin):   w = (end - k)   / (end  - peak)
  int offset = 0;
  for (int m = 0; m < MEL_N_MELS; m++) {
    int s = melFilters[m].startBin;
    int p = melFilters[m].peakBin;
    int e = melFilters[m].endBin;
    int width = e - s;
    melFiltersFlat[m].startBin = s;
    melFiltersFlat[m].width    = width;
    melFiltersFlat[m].offset   = offset;
    float rise_inv = (p > s) ? 1.0f / (float)(p - s) : 0.0f;
    float fall_inv = (e > p) ? 1.0f / (float)(e - p) : 0.0f;
    for (int k = s; k < e; k++) {
      float w;
      if (k < p)       w = (float)(k - s) * rise_inv; // rising
      else if (k == p) w = 1.0f;                       // peak
      else             w = (float)(e - k) * fall_inv;  // falling
      melWeightFlat[offset + (k - s)] = w;
    }
    offset += width;
  }
}

// =========================================================
// Mel Spectrogram — FFT-based, matching DrongoNet-edge training
// =========================================================
//
// Reproduces this librosa chain on the MCU:
//   mel_spec = librosa.feature.melspectrogram(
//       y=waveform, sr=16000, n_fft=1024, hop_length=256,
//       n_mels=80, fmin=100, fmax=8000, center=False)
//   mel_db   = librosa.power_to_db(mel_spec, ref=np.max)
//   mel_norm = (mel_db - mel_db.min()) / (mel_db.max() - mel_db.min() + 1e-8)
//
// PIPELINE (per frame):
//   1. int16 → float + Hann window (fused, single pass)
//   2. arm_rfft_fast_f32 (hardware Real FFT, N=1024)
//   3. |X[k]|² power spectrum (DC + Nyquist + SIMD bins 1..511)
//   4. Triangular mel filterbank dot-product (4-way unrolled)
//   5. Power → dB (fast_log10f IEEE-754 trick)
//   6. Global min-max normalisation (SIMD arm_offset + arm_scale)
//
// OUTPUT: melOut[f * MEL_N_MELS + m] in [0, 1], row-major (time × mel)
// ─────────────────────────────────────────────────────────────────
void computeMelSpectrogram(int16_t *audio, int audioLength, float *melOut) {

  for (int f = 0; f < TIME_FRAMES; f++) {
    int frameStart   = f * MEL_HOP_LENGTH;
    int validSamples = audioLength - frameStart;
    if (validSamples > MEL_N_FFT) validSamples = MEL_N_FFT;

    // ── 1. Fused int16→float + Hann window (OPT-A) ────────────────
    // Avoids a separate arm_q15_to_float + arm_mult_f32 pass.
    // Single write: fftBuf[i] = audio[i] * hannScaled[i]
    const float INV_32768 = 1.0f / 32768.0f;
    const int16_t *src = &audio[frameStart];
    for (int i = 0; i < validSamples; i++) {
      fftBuf[i] = (float)src[i] * (hannWindow[i] * INV_32768);
    }
    // Zero-pad the tail (only the last frame is ever short)
    if (validSamples < MEL_N_FFT) {
      memset(&fftBuf[validSamples], 0,
             (MEL_N_FFT - validSamples) * sizeof(float));
    }

    // ── 2. Real FFT (CMSIS hardware-accelerated) ───────────────────
    // Output packing in fftBuf[0..N-1]:
    //   fftBuf[0]    = DC   component (real only)
    //   fftBuf[1]    = Nyquist component (real only)
    //   fftBuf[2k]   = Re[k]  for k = 1..N/2-1
    //   fftBuf[2k+1] = Im[k]  for k = 1..N/2-1
    arm_rfft_fast_f32(&fftInstance, fftBuf, fftBuf, 0 /*forward*/);

    // ── 3. Power spectrum |X[k]|² for k = 0..N/2 ──────────────────
    // DC bin (k=0): fftBuf[0]^2
    powerSpectrum[0] = fftBuf[0] * fftBuf[0];
    // Nyquist bin (k=N/2): fftBuf[1]^2
    powerSpectrum[MEL_N_FFT / 2] = fftBuf[1] * fftBuf[1];
    // Bins 1..N/2-1: arm_cmplx_mag_squared_f32 computes Re²+Im²
    arm_cmplx_mag_squared_f32(&fftBuf[2], &powerSpectrum[1],
                              MEL_N_FFT / 2 - 1);

    // ── 4+5. Filterbank dot-product → dB (OPT-B: 4-way unrolled) ──
    // Replaces mel_bins × arm_dot_prod_f32() calls with an inline
    // 4-wide unrolled loop that the compiler can dual-issue on M7.
    float *melRow = &melOut[f * MEL_N_MELS];
    for (int m = 0; m < MEL_N_MELS; m++) {
      const float *P = &powerSpectrum[melFiltersFlat[m].startBin];
      const float *W = &melWeightFlat[melFiltersFlat[m].offset];
      int   width    =  melFiltersFlat[m].width;

      float acc0 = 0.0f, acc1 = 0.0f, acc2 = 0.0f, acc3 = 0.0f;
      int k = 0;
      for (; k <= width - 4; k += 4) {
        acc0 += P[k+0] * W[k+0];
        acc1 += P[k+1] * W[k+1];
        acc2 += P[k+2] * W[k+2];
        acc3 += P[k+3] * W[k+3];
      }
      float acc = (acc0 + acc1) + (acc2 + acc3);
      for (; k < width; k++) {
        acc += P[k] * W[k];
      }

      // Power → dB using fast IEEE-754 log10 approximation
      melRow[m] = 10.0f * fast_log10f(acc + 1e-10f);
    }
  } // end frame loop

  // ── 6. Global min-max normalisation (OPT-C: SIMD) ─────────────
  // Matches training pipeline:
  //   mel_norm = (mel_db - mel_db.min()) / (mel_db.max() - mel_db.min())
  // arm_min/max_f32: SIMD scan, 4 float/cycle
  // arm_offset_f32:  out[i] = in[i] + offset  (SIMD)
  // arm_scale_f32:   out[i] = in[i] * scale   (SIMD)
  float globalMin, globalMax;
  uint32_t minIdx, maxIdx;
  arm_min_f32(melOut, INPUT_SIZE, &globalMin, &minIdx);
  arm_max_f32(melOut, INPUT_SIZE, &globalMax, &maxIdx);

  float range = globalMax - globalMin;
  if (range < 1e-6f) range = 1e-6f;
  float invRange = 1.0f / range;

  arm_offset_f32(melOut, -globalMin, melOut, INPUT_SIZE);
  arm_scale_f32(melOut, invRange, melOut, INPUT_SIZE);

  // Clamp to [0, 1] for numeric safety
  for (int i = 0; i < INPUT_SIZE; i++) {
    float v = melOut[i];
    if (v < 0.0f) v = 0.0f;
    if (v > 1.0f) v = 1.0f;
    melOut[i] = v;
  }
}

// =========================================================
// Audio capture — busy-wait precise timing at 16 kHz
// NOTE: Portenta H7 default ADC is 12-bit (0–4095).
//       Centre at 2048, full-scale ±2048.
// =========================================================
void captureAudio() {
  const unsigned long sampleInterval = 1000000UL / SAMPLE_RATE;
  unsigned long lastSample = micros();
  for (int i = 0; i < BUFFER_SIZE; i++) {
    while (micros() - lastSample < sampleInterval) {
    }
    lastSample = micros();
    int val = analogRead(MIC_PIN);
    // 12-bit ADC: centre at 2048, full-scale ±2048
    float sample = ((float)val - 2048.0f) / 2048.0f;
    audioBuffer[i] = (int16_t)(sample * 32767);
  }
}

// =========================================================
// SETUP
// =========================================================
void setup() {
  Serial.begin(115200);
  pinMode(LED_BUILTIN, OUTPUT);
  delay(2000);

  // ── Enable DWT Cycle Counter ────────────────────────────────────
  DWT_ENABLE();

  Serial.println(F("=== DrongoNet-edge (80-mel) — Memory Profiling Build ==="));
  Serial.print(F("MEL_BINS="));   Serial.print(MEL_BINS);
  Serial.print(F("  TIME_FRAMES=")); Serial.print(TIME_FRAMES);
  Serial.print(F("  INPUT_SIZE=")); Serial.println(INPUT_SIZE);
  Serial.print(F("FFT_SIZE="));    Serial.print(MEL_N_FFT);
  Serial.print(F("  HOP="));       Serial.print(MEL_HOP_LENGTH);
  Serial.print(F("  FMIN="));      Serial.print(MEL_FMIN);
  Serial.print(F("  FMAX="));      Serial.println(MEL_FMAX);

  // ── Step 0: Initialise SDRAM ─────────────────────────────────────
  SDRAM.begin();
  Serial.println(F("[OK]  SDRAM initialised (8 MB at 0x60000000)."));

  // ── Step 1: Allocate tensor arena from SDRAM ──────────────────────
  uint8_t *raw = (uint8_t *)SDRAM.malloc(kTensorArenaSize + 15);
  if (!raw) {
    Serial.println(F("[ERR] SDRAM.malloc() failed for tensor_arena."));
    while (1) { digitalWrite(LED_BUILTIN, !digitalRead(LED_BUILTIN)); delay(200); }
  }
  uintptr_t addr    = (uintptr_t)raw;
  uintptr_t aligned = (addr + 15u) & ~15u;
  tensor_arena = (uint8_t *)aligned;

  Serial.print(F("[OK]  tensor_arena allocated in SDRAM at 0x"));
  Serial.print((uint32_t)tensor_arena, HEX);
  Serial.print(F(", size = "));
  Serial.print(kTensorArenaSize / 1024);
  Serial.println(F(" KB."));

  // ── INA219 ──────────────────────────────────────────────────────
  Wire.begin();
  if (ina219.begin()) {
    ina219_ok    = true;
    lastPowerMs  = millis();
    Serial.println(F("[OK]  INA219 initialised."));
  } else {
    Serial.println(F("[WARN] INA219 not found — power data skipped."));
  }

  // ── Load model ────────────────────────────────────────────────────
  model = tflite::GetModel(drongonet_edge);
  if (!model) {
    Serial.println(F("[ERR] tflite::GetModel() returned null."));
    while (1) {}
  }
  if (model->version() != TFLITE_SCHEMA_VERSION) {
    Serial.print(F("[ERR] Schema mismatch: got="));
    Serial.print(model->version());
    Serial.print(F(" expected="));
    Serial.println(TFLITE_SCHEMA_VERSION);
    while (1) {}
  }

  // ── Build interpreter ─────────────────────────────────────────────
  // AllOpsResolver: DrongoNet-edge uses only standard ops
  // (CONV_2D, MAX_POOL_2D, MEAN, FULLY_CONNECTED, RELU, SOFTMAX).
  static tflite::AllOpsResolver resolver;
  static tflite::MicroInterpreter static_interpreter(
      model, resolver, tensor_arena, kTensorArenaSize);
  interpreter = &static_interpreter;

  // ── Allocate tensors ──────────────────────────────────────────────
  TfLiteStatus alloc_status = interpreter->AllocateTensors();
  if (alloc_status != kTfLiteOk) {
    Serial.println(F("[ERR] AllocateTensors() failed."));
    Serial.print(F("      Current arena = "));
    Serial.print(kTensorArenaSize / 1024);
    Serial.println(F(" KB — increase kTensorArenaSize and reflash."));
    while (1) {}
  }

  inputTensor  = interpreter->input(0);
  outputTensor = interpreter->output(0);

  // Sanity-check: input must match MEL_BINS × TIME_FRAMES (INT8 → 1 B/elem)
  if (inputTensor->bytes != (uint32_t)INPUT_SIZE) {
    Serial.print(F("[ERR] Input tensor byte count mismatch: model expects "));
    Serial.print(inputTensor->bytes);
    Serial.print(F(" B but firmware has INPUT_SIZE="));
    Serial.println(INPUT_SIZE);
    Serial.println(F("      Check MEL_BINS and TIME_FRAMES constants."));
    while (1) {}
  }

  // Sanity-check: output must be 2-element (softmax)
  if (outputTensor->bytes != 2) {
    Serial.print(F("[WARN] Expected 2-element softmax output, got "));
    Serial.print(outputTensor->bytes);
    Serial.println(F(" bytes — output decoding may be wrong."));
  }

  // ── Initialise CMSIS-DSP FFT + Hann window + filterbank ──────────
  initMelFFT();
  Serial.println(F("[OK]  CMSIS-DSP RFFT + Hann window + mel filterbank initialised."));
  Serial.print(F("      FFT size: ")); Serial.print(MEL_N_FFT);
  Serial.print(F("  hop: "));         Serial.print(MEL_HOP_LENGTH);
  Serial.print(F("  mels: "));        Serial.println(MEL_N_MELS);

  printFlashMemory();
  printTFLMMemory();
  printFirmwareRAM();

  Serial.println(F("\n[OK]  DrongoNet-edge (80-mel) inference engine ready."));
}

// =========================================================
// MAIN LOOP
// =========================================================
void loop() {

  if (!firstLoopDone) {
    Serial.println();
    Serial.println(F("========== PIPELINE BUFFER INFO =========="));
    Serial.print(F("audioBuffer [48000×int16]  : "));
    Serial.print(BUFFER_SIZE * (uint32_t)sizeof(int16_t));
    Serial.println(F(" B  (global .bss / AXI SRAM)"));
    Serial.print(F("melFeatures [14720×float]  : "));
    Serial.print(INPUT_SIZE * (uint32_t)sizeof(float));
    Serial.println(F(" B  (global .bss / AXI SRAM)"));
    Serial.print(F("tensor input buf           : "));
    Serial.print(inputTensor->bytes);
    Serial.println(F(" B  (arena HEAD, SDRAM)"));
    Serial.print(F("tensor output buf          : "));
    Serial.print(outputTensor->bytes);
    Serial.println(F(" B  (arena HEAD, 2-element softmax, SDRAM)"));
    Serial.print(F("Input tensor dims          : ["));
    for (int i = 0; i < inputTensor->dims->size; i++) {
      Serial.print(inputTensor->dims->data[i]);
      if (i < inputTensor->dims->size - 1)
        Serial.print(',');
    }
    Serial.println(F("]"));
    Serial.println(F("==========================================\n"));
    firstLoopDone = true;
  }

  unsigned long startTime = millis();

  // ── STAGE 1: Audio capture ───────────────────────────────────────
  StageRAM before_capture = snapshotRAM();
  captureAudio();
  StageRAM after_capture = snapshotRAM();
  unsigned long captureTime = millis() - startTime;

  // ── RMS Energy Gate ──────────────────────────────────────────────
  // Compute RMS of the captured int16 buffer.
  // Below RMS_THRESHOLD → silence/background; skip inference.
  // This prevents per-sample min-max from amplifying silence
  // into a false-positive input to the model.
  float rmsAccum = 0.0f;
  for (int i = 0; i < BUFFER_SIZE; i++) {
    float s = (float)audioBuffer[i];
    rmsAccum += s * s;
  }
  float rms = sqrtf(rmsAccum / (float)BUFFER_SIZE);

  if (rms < RMS_THRESHOLD) {
    Serial.print(F("[GATE] Silent window — RMS="));
    Serial.print(rms, 1);
    Serial.print(F(" < threshold="));
    Serial.print(RMS_THRESHOLD, 0);
    Serial.println(F(" — inference skipped."));
    delay(100);
    return;
  }

  // ── STAGE 2: Mel Spectrogram (FFT-based) ─────────────────────────
  StageRAM before_mel = snapshotRAM();

  // DWT-based cycle measurement for µs-accurate mel timing.
  DWT_RESET();
  unsigned long melStart = millis();
  computeMelSpectrogram(audioBuffer, BUFFER_SIZE, melFeatures);
  uint32_t melCycles = DWT_CYCLES(); // read immediately after return
  unsigned long melTime = millis() - melStart;
  float melUs = DWT_US(melCycles);

  StageRAM after_mel = snapshotRAM();

  // ── STAGE 3: Quantise and fill input tensor ───────────────────────
  // melFeatures[] is in [0, 1]; dequantise to INT8 using
  // the tensor's affine quantisation parameters (scale, zero_point).
  for (int i = 0; i < INPUT_SIZE; i++) {
    float scaled = melFeatures[i] / inputTensor->params.scale +
                   inputTensor->params.zero_point;
    if (scaled >  127.0f) scaled =  127.0f;
    if (scaled < -128.0f) scaled = -128.0f;
    inputTensor->data.int8[i] = (int8_t)scaled;
  }

  // ── STAGE 4: Inference ────────────────────────────────────────────
  StageRAM before_infer = snapshotRAM();
  unsigned long inferStart = millis();
  TfLiteStatus invoke_status = interpreter->Invoke();
  unsigned long inferTime = millis() - inferStart;
  StageRAM after_infer = snapshotRAM();

  if (invoke_status != kTfLiteOk) {
    Serial.println(F("[ERR] Invoke() failed — check arena size / model compatibility."));
    return;
  }

  // ── STAGE 5: Decode output ────────────────────────────────────────
  // 2-element INT8 softmax output.
  // [0] = P(no_bird)    [1] = P(bird)
  float out_scale = outputTensor->params.scale;
  int   out_zp    = outputTensor->params.zero_point;

  float prob_no_bird = (outputTensor->data.int8[0] - out_zp) * out_scale;
  float prob_bird    = (outputTensor->data.int8[1] - out_zp) * out_scale;

  // One-time output diagnostic
  static bool outputDiagPrinted = false;
  if (!outputDiagPrinted) {
    outputDiagPrinted = true;
    Serial.println(F("\n--- OUTPUT DIAGNOSTIC ---"));
    Serial.print(F("  outputTensor->bytes = ")); Serial.println(outputTensor->bytes);
    Serial.print(F("  scale = "));   Serial.print(out_scale, 6);
    Serial.print(F("  zp = "));      Serial.println(out_zp);
    Serial.print(F("  raw int8[0] = ")); Serial.print(outputTensor->data.int8[0]);
    Serial.print(F("  raw int8[1] = ")); Serial.println(outputTensor->data.int8[1]);
    Serial.print(F("  P(no_bird) = ")); Serial.print(prob_no_bird, 4);
    Serial.print(F("  P(bird) = "));    Serial.println(prob_bird, 4);
    Serial.println(F("--- END OUTPUT DIAGNOSTIC ---\n"));
  }

  // ── Temporal smoothing (3-window ring buffer) ─────────────────────
  scoreHistory[scoreHistIdx % 3] = prob_bird;
  scoreHistIdx++;
  float avgScore = (scoreHistory[0] + scoreHistory[1] + scoreHistory[2]) / 3.0f;
  bool  birdDetected = (avgScore > 0.6f);
  digitalWrite(LED_BUILTIN, birdDetected ? HIGH : LOW);

  // ── Print inference result ─────────────────────────────────────────
  Serial.print(F("Detection: "));
  Serial.print(birdDetected ? F("BIRD") : F("no bird"));
  Serial.print(F(" | P(bird)="));   Serial.print(prob_bird, 4);
  Serial.print(F(" | P(no_bird)=")); Serial.print(prob_no_bird, 4);
  Serial.print(F(" | AvgScore="));  Serial.print(avgScore, 4);
  Serial.print(F(" | RMS="));       Serial.print(rms, 0);
  Serial.print(F(" | capture="));   Serial.print(captureTime);
  Serial.print(F("ms mel="));       Serial.print(melTime);
  Serial.print(F("ms infer="));     Serial.print(inferTime);
  Serial.print(F("ms | mel_cyc=")); Serial.print(melCycles);
  Serial.print(F(" mel_us="));      Serial.print(melUs, 1);
  Serial.println(F(" µs"));

  // ── Per-stage RAM deltas (every 10 loops) ─────────────────────────
  static uint32_t loopCount = 0;
  const uint32_t LOG_INTERVAL = 10;
  if (++loopCount % LOG_INTERVAL == 0) {
    Serial.println(F("\n--- Transient RAM per pipeline stage ---"));
    printStageDelta("1_capture", before_capture, after_capture);
    printStageDelta("2_mel    ", before_mel, after_mel);
    printStageDelta("3_infer  ", before_infer, after_infer);

    mbed_stats_heap_t heap;
    mbed_stats_heap_get(&heap);
    Serial.print(F("  Heap: current="));
    Serial.print(heap.current_size);
    Serial.print(F("B  peak="));
    Serial.print(heap.max_size);
    Serial.print(F("B  failures="));
    Serial.println(heap.alloc_fail_cnt);
    Serial.println(F("----------------------------------------\n"));
  }

  // ── Power & Energy Breakdown ─────────────────────────────────────────
  // Single INA219 snapshot after all compute stages complete.
  // Cortex-M7 @ 480 MHz runs at 100% duty cycle during mel + infer,
  // so instantaneous power represents the active load well.
  // E(µJ) = P(mW) × t(ms)   [mW × ms = µW·s = µJ]
  if (ina219_ok) {
    float busV   = ina219.getBusVoltage_V();
    float cur_mA = ina219.getCurrent_mA();
    float pwr_mW = ina219.getPower_mW();

    // Accumulate session energy (whole loop wall-clock time)
    uint32_t now = millis();
    float dt_h   = (now - lastPowerMs) / 3600000.0f;
    lastPowerMs  = now;
    if (pwr_mW > 0.0f)
      total_energy_mWh += pwr_mW * dt_h;

    // Per-stage energy derived from DWT / millis() durations
    float energy_mel_uJ   = pwr_mW * (float)melTime;    // mel computation
    float energy_infer_uJ = pwr_mW * (float)inferTime;  // inference
    float energy_total_uJ = pwr_mW * (float)(melTime + inferTime); // active compute

    Serial.println(F("\n─────────── Power & Energy ──────────────"));
    Serial.print(F("  Instantaneous  : "));
    Serial.print(pwr_mW, 2);
    Serial.print(F(" mW  ("));
    Serial.print(busV, 2);
    Serial.print(F(" V, "));
    Serial.print(cur_mA, 2);
    Serial.println(F(" mA)"));
    Serial.println(F("  [Energy — current cycle]"));
    Serial.print(F("    Mel computation : "));
    Serial.print(energy_mel_uJ, 2);
    Serial.println(F(" µJ"));
    Serial.print(F("    Inference       : "));
    Serial.print(energy_infer_uJ, 2);
    Serial.println(F(" µJ"));
    Serial.print(F("    Total (active)  : "));
    Serial.print(energy_total_uJ, 2);
    Serial.println(F(" µJ"));
    Serial.print(F("  Session cumulative: "));
    Serial.print(total_energy_mWh, 6);
    Serial.println(F(" mWh"));
    Serial.println(F("─────────────────────────────────────────"));
  }

  Serial.println();
  delay(100);
}
